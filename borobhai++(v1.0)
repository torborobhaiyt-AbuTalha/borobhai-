enum TokenType {
    KEYWORD_DHORI, KEYWORD_LEKHO, KEYWORD_BANAU_GAME, KEYWORD_AKO_OBJECT,
    KEYWORD_SIN, KEYWORD_COS, KEYWORD_TAN, KEYWORD_LOG, KEYWORD_LN, KEYWORD_ROOT, KEYWORD_POWER,
    KEYWORD_PI, KEYWORD_E, KEYWORD_GRAVITY,
    IDENTIFIER, NUMBER, STRING, ASSIGN, PLUS, MINUS, MULTIPLY, DIVIDE, COLON, EOF_TOKEN
};

struct Token {
    TokenType type;
    std::string value;
};

