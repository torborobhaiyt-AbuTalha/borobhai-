using RuntimeVal = std::variant<double, std::string>;

class Interpreter {
private:
    std::unordered_map<std::string, RuntimeVal> symbol_table;
    double get_d(RuntimeVal v) { return std::holds_alternative<double>(v) ? std::get<double>(v) : 0.0; }

public:
    void execute(std::vector<Token> tokens) {
        size_t i = 0;
        while (i < tokens.size() && tokens[i].type != EOF_TOKEN) {
            
            // layer 5 dhori
            if (tokens[i].type == KEYWORD_DHORI) {
                std::string var = tokens[i+1].value;
                i += 3;

                if (tokens[i].type == KEYWORD_PI) { symbol_table[var] = 3.1415926535; i++; }
                else if (tokens[i].type == KEYWORD_E) { symbol_table[var] = 2.7182818284; i++; }
                else if (tokens[i].type == KEYWORD_ROOT) {
                    double arg = (tokens[i+1].type == NUMBER) ? std::stod(tokens[i+1].value) : get_d(symbol_table[tokens[i+1].value]);
                    symbol_table[var] = std::sqrt(arg); i += 2;
                }
                else if (tokens[i].type == KEYWORD_SIN) {
                    double arg = (tokens[i+1].type == NUMBER) ? std::stod(tokens[i+1].value) : get_d(symbol_table[tokens[i+1].value]);
                    symbol_table[var] = std::sin(arg * 3.1415926535 / 180.0); i += 2;
                }
                else if (tokens[i].type == KEYWORD_COS) {
                    double arg = (tokens[i+1].type == NUMBER) ? std::stod(tokens[i+1].value) : get_d(symbol_table[tokens[i+1].value]);
                    symbol_table[var] = std::cos(arg * 3.1415926535 / 180.0); i += 2;
                }
                else if (tokens[i].type == KEYWORD_LOG) {
                    double arg = (tokens[i+1].type == NUMBER) ? std::stod(tokens[i+1].value) : get_d(symbol_table[tokens[i+1].value]);
                    symbol_table[var] = std::log10(arg); i += 2;
                }
                else if (tokens[i].type == KEYWORD_POWER) {
                    double base = (tokens[i+1].type == NUMBER) ? std::stod(tokens[i+1].value) : get_d(symbol_table[tokens[i+1].value]);
                    double p = (tokens[i+2].type == NUMBER) ? std::stod(tokens[i+2].value) : get_d(symbol_table[tokens[i+2].value]);
                    symbol_table[var] = std::pow(base, p); i += 3;
                }
                else if (tokens[i].type == NUMBER) {
                    symbol_table[var] = std::stod(tokens[i].value); i++;
                }
                else if (tokens[i].type == STRING) {
                    symbol_table[var] = tokens[i].value; i++;
                }
            }
            // layer 6
            else if (tokens[i].type == KEYWORD_BANAU_GAME) {
                gameTitle = tokens[i+1].value;
                runPhysicsGame = true;
                i += 2;
            }
            // layer 7
            else if (tokens[i].type == KEYWORD_AKO_OBJECT) {
                objX = (int)get_d(symbol_table[tokens[i+1].value]);
                objY = (int)get_d(symbol_table[tokens[i+2].value]);
                i += 3;
            }
            // লেখো (Print)
            else if (tokens[i].type == KEYWORD_LEKHO) {
                if (tokens[i+1].type == STRING) std::cout << tokens[i+1].value << std::endl;
                else {
                    RuntimeVal v = symbol_table[tokens[i+1].value];
                    if (std::holds_alternative<double>(v)) std::cout << std::get<double>(v) << std::endl;
                    else std::cout << std::get<std::string>(v) << std::endl;
                }
                i += 2;
            } else { i++; }
        }

        // layer 8
        if (runPhysicsGame) {
            HINSTANCE h = GetModuleHandle(NULL);
            WNDCLASS wc = {}; wc.lpfnWndProc = WindowProc; wc.hInstance = h; wc.lpszClassName = "BCFinal";
            RegisterClass(&wc);
            HWND hwnd = CreateWindowEx(0, "BCFinal", gameTitle.c_str(), WS_OVERLAPPEDWINDOW | WS_VISIBLE, CW_USEDEFAULT, CW_USEDEFAULT, 800, 600, NULL, NULL, h, NULL);
            
            SetTimer(hwnd, 1, 16, NULL); // ১৬ মিলিলাইনের গেম টিক লুপ (প্রায় ৬০ FPS)
            MSG msg = {};
            while (GetMessage(&msg, NULL, 0, 0)) { TranslateMessage(&msg); DispatchMessage(&msg); }
        }
    }
};

int main(int argc, char* argv[]) {
    if (argc < 2) { std::cout << "ব্যবহার: banglacode <file.bc>\n"; return 1; }
    std::ifstream file(argv[1]); if (!file.is_open()) return 1;
    std::string src((std::istreambuf_iterator<char>(file)), std::istreambuf_iterator<char>()); file.close();
    Lexer lexer(src); Interpreter engine; engine.execute(lexer.tokenize());
    return 0;
}

