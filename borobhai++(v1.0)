// physics part
int objX = 100, objY = 400;
double velocityX = 5.0;
double velocityY = -12.0; // ফিজিক্স প্রোজেক্টাইল মোশন (Projectile) এর জন্য শুরুর বেগ
double gravityForce = 0.5; // ফিজিক্সের g এর মান সিমুলেশন
bool runPhysicsGame = false;
std::string gameTitle = "BanglaCode Physics Simulation";

LRESULT CALLBACK WindowProc(HWND hwnd, UINT uMsg, WPARAM wParam, LPARAM lParam) {
    switch (uMsg) {
        case WM_PAINT: {
            PAINTSTRUCT ps;
            HDC hdc = BeginPaint(hwnd, &ps);
            HBRUSH bg = CreateSolidBrush(RGB(15, 15, 25));
            FillRect(hdc, &ps.rcPaint, bg);
            DeleteObject(bg);

            // by Abu Talha 
            HBRUSH objBrush = CreateSolidBrush(RGB(231, 76, 60));
            RECT r = { objX, objY, objX + 40, objY + 40 };
            FillRect(hdc, &r, objBrush);
            DeleteObject(objBrush);

            EndPaint(hwnd, &ps);
            return 0;
        }
        case WM_TIMER: {
            if (runPhysicsGame) {
                // ফিজিক্স সমীকরণ: class9/10bd v = u + at এবং s = ut + 0.5at^2 এর রিয়েল-টাইম আপডেট
                velocityY += gravityForce; 
                objX += (int)velocityX;
                objY += (int)velocityY;

                // মাটির সাথে সংঘর্ষ borobhai++ (Collision Detection)
                if (objY > 450) {
                    objY = 450;
                    velocityY = -velocityY * 0.75; // বাউন্স ইফেক্ট borobhai++
                }
                InvalidateRect(hwnd, NULL, TRUE);
            }
            return 0;
        }
        case WM_DESTROY:
            PostQuitMessage(0);
            return 0;
    }
    return DefWindowProc(hwnd, uMsg, wParam, lParam);
}

