class Lexer {
private:
    std::string src;
    size_t pos = 0;
public:
    Lexer(std::string source) : src(source) {}
    std::vector<Token> tokenize() {
        std::vector<Token> tokens;
        while (pos < src.length()) {
            char current = src[pos];
            if (isspace(current)) { pos++; continue; }
            if (current == '"') {
                std::string str = ""; pos++;
                while (pos < src.length() && src[pos] != '"') { str += src[pos]; pos++; }
                pos++; tokens.push_back({STRING, str}); continue;
            }
            if (current == '=') { tokens.push_back({ASSIGN, "="}); pos++; continue; }
            if (current == '+') { tokens.push_back({PLUS, "+"}); pos++; continue; }
            if (current == '-') { tokens.push_back({MINUS, "-"}); pos++; continue; }
            if (current == '*') { tokens.push_back({MULTIPLY, "*"}); pos++; continue; }
            if (current == '/') { tokens.push_back({DIVIDE, "/"}); pos++; continue; }
            if (current == ':') { tokens.push_back({COLON, ":"}); pos++; continue; }

            std::string word = "";
            while (pos < src.length() && !isspace(src[pos]) && src[pos] != '=' && 
                   src[pos] != '+' && src[pos] != '-' && src[pos] != '*' && src[pos] != '/' && src[pos] != ':' && src[pos] != '"') {
                word += src[pos]; pos++;
            }
            if (!word.empty()) {
                if (word == "ধরি") tokens.push_back({KEYWORD_DHORI, word});
                else if (word == "লেখো") tokens.push_back({KEYWORD_LEKHO, word});
                else if (word == "বানাও_গেম") tokens.push_back({KEYWORD_BANAU_GAME, word});
                else if (word == "আঁকো_অবজেক্ট") tokens.push_back({KEYWORD_AKO_OBJECT, word});
                else if (word == "সাইন") tokens.push_back({KEYWORD_SIN, word});
                else if (word == "কস") tokens.push_back({KEYWORD_COS, word});
                else if (word == "ট্যান") tokens.push_back({KEYWORD_TAN, word});
                else if (word == "লগ") tokens.push_back({KEYWORD_LOG, word});
                else if (word == "লন") tokens.push_back({KEYWORD_LN, word});
                else if (word == "রুট") tokens.push_back({KEYWORD_ROOT, word});
                else if (word == "পাওয়ার") tokens.push_back({KEYWORD_POWER, word});
                else if (word == "পাই") tokens.push_back({KEYWORD_PI, word});
                else if (word == "ই_ধ্রুবক") tokens.push_back({KEYWORD_E, word});
                else if (word == "অভিকর্ষ") tokens.push_back({KEYWORD_GRAVITY, word});
                else if (isdigit(word[0]) || (word[0] == '-' && isdigit(word[1]))) tokens.push_back({NUMBER, word});
                else tokens.push_back({IDENTIFIER, word});
            }
        }
        tokens.push_back({EOF_TOKEN, ""});
        return tokens;
    }
};

